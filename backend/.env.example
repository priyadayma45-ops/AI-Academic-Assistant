# Spring Boot Configuration Environment Variables Example

# Active Spring Profile (e.g. 'prod' for MySQL/Redis production or 'test' for H2 memory database)
SPRING_PROFILES_ACTIVE=test

# Database configuration (MySQL connection coordinates)
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/academic_assistant?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_mysql_password

# Authentication (Secure 256-bit signature secret key)
APP_JWT_SECRET=9a676781b2e143c7b60e9d6d2a4e21a37c4d5e6f7g8h9i0j1k2l3m4n5o6p7q8r9s0t1u2v3w4x5y6z

# Redis cache server config (Required in production)
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379

# Google Gemini API key config (Obtain from Google AI Studio Developer Console)
APP_GEMINI_API_KEY=AIzaSyYourGeminiApiKeyHere
