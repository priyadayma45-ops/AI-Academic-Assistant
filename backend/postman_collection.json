					"mode": "raw",
					"raw": "{\n    \"email\": \"student@test.com\",\n    \"password\": \"password123\",\n    \"name\": \"John Doe\",\n    \"role\": \"STUDENT\",\n    \"college\": \"Stanford University\",\n    \"branch\": \"Computer Science\",\n    \"semester\": \"Semester 4\"\n}"
				},
				"url": {
					"raw": "http://localhost:8080/api/v1/auth/signup",
					"protocol": "http",
					"host": [
						"localhost"
					],
					"port": "8080",
					"path": [
